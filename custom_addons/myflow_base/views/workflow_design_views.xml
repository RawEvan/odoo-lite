<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_cr_workflow_design_tree" model="ir.ui.view">
      <field name="name">cr.workflow.design.tree</field>
      <field name="model">cr.workflow.design</field>
      <field name="arch" type="xml">
        <list>
          <field name="sequence"/>
          <field name="name"/>
          <field name="key"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_cr_workflow_design_form" model="ir.ui.view">
      <field name="name">cr.workflow.design.form</field>
      <field name="model">cr.workflow.design</field>
      <field name="arch" type="xml">
        <form>
          <sheet>
            <group>
              <field name="name"/>
              <field name="key"/>
              <field name="sequence"/>
              <field name="active"/>
            </group>
            <group>
              <field name="description"/>
            </group>
            <group>
              <field name="layout" widget="text"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="action_cr_workflow_design" model="ir.actions.act_window">
      <field name="name">Workflow Design</field>
      <field name="res_model">cr.workflow.design</field>
      <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_myflow_base_root" name="Workflow Platform" sequence="70"/>
    <menuitem
      id="menu_cr_workflow_design"
      name="Workflow Design"
      parent="menu_myflow_base_root"
      action="action_cr_workflow_design"
      sequence="10"
    />
  </data>
</odoo>

